    {
        "id": "04cd9e7d63dc0c98",
        "type": "function",
        "z": "383d3fb3fe46745a",
        "name": "function 2",
        "func": "if (msg.payload.Temperature > 60) {\n    msg.payload.Temperature = 60;\n}\n\nif (msg.payload.Humidity < 0) {\n    msg.payload.Humidity = 0;\n} else if (msg.payload.Humidity > 100) {\n    msg.payload.Humidity = 100;\n}\n\nif (msg.payload.Soil_Moisture < 0) {\n    msg.payload.Soil_Moisture = 0;\n} else if (msg.payload.Soil_Moisture > 100) {\n    msg.payload.Soil_Moisture = 100;\n}\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 940,
        "y": 200,
        "wires": [
            [
                "2b14afc2af428385"
            ]
        ]
    },
    {
        "id": "edcae52d06af1218",
        "type": "function",
        "z": "383d3fb3fe46745a",
        "name": "function 3",
        "func": "// Extract the numeric prediction value\nlet prediction = msg.payload.irrigation_prediction;\n\n// Recommendation logic (Status is optimal vs ALERT)\nlet statusString = (prediction > 0.5) ?\n    \"⚠️ ALERT: High Water Demand (\" + prediction.toFixed(2) + \"mm)! Manual action required.\" :\n    \"✅ Status: Soil moisture is optimal. No action needed.\";\n\n// Output 1: String for the Text widget\nlet textMsg = {\n    payload: statusString\n};\n\n// Output 2: String for the Alert widget (Toast)\nlet alertMsg = null;\nif (prediction > 0.5) {\n    alertMsg = {\n        payload: \"Critical Warning: Activate Irrigation System Immediately!\"\n    };\n}\n\n// [Port 1, Port 2]\nreturn [textMsg, alertMsg];",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1520,
        "y": 300,
        "wires": [
            [],
            [
                "1aedd3f034a2802d"
            ]
        ]
    },
