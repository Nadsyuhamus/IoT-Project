    {
        "id": "141d1ec4b03cf839",
        "type": "function",
        "z": "383d3fb3fe46745a",
        "name": "function 1",
        "func": "// Preprocessing Step 1: Data Validation\n// This ensures we don't send \"empty\" rows to the ML model\nif (msg.payload.Temperature && msg.payload.Humidity && msg.payload.Soil_Moisture) {\n    return msg; // Valid data: Proceed to the next node\n}\n\n// Invalid/Empty data: Stop the flow here to save server resources\nreturn null;",
