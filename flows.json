    {
        "id": "e2f598daf00c22c6",
        "type": "function",
        "z": "538a03d09de52284",
        "name": "System Integration",
        "func": "// 1. Safe Data Extraction from FastAPI\nconst data = msg.payload || {};\nconst sensors = data.features_received || {};\nconst prediction = data.irrigation_prediction || 0;\nconst baseline = data.baseline_triggered;\n\nconst temp = sensors.Temperature ?? 0;\nconst moist = sensors.Soil_Moisture ?? 0;\n\n// 2. Contextual AI Decision\n// Rule: Use the API's 0.5 standard recommendation OR \n// trigger a 'Smart Action' if it's hot (>50C) and prediction is >0.40\nconst ml_decision = data.irrigation_recommended || (prediction >= 0.40 && temp > 50);\n\n// 3. Safety Logic\nlet sensorError = (temp >= 60 || moist > 100 || moist < 0 || isNaN(temp));\n\n// 4. Status Priority Logic (Fulfills Baseline Comparison requirement)\nlet statusMsg = \"\";\nif (sensorError) {\n    statusMsg = \"CRITICAL: Sensor Error. System Locked.\";\n} else if (ml_decision && !baseline && temp > 50) {\n    // Triggers ONLY during high heat stress\n    statusMsg = \"AI SMART ACTION: Heatwave detected (Moisture >30%)\";\n} else if (ml_decision) {\n    // Triggers for standard drying (Baseline or standard ML recommendation)\n    statusMsg = \"Irrigation Active\";\n} else if (!ml_decision && baseline) {\n    // AI avoids watering despite low moisture (e.g. high humidity)\n    statusMsg = \"AI WATER SAVING: Optimal conditions. Skipping.\";\n} else {\n    statusMsg = \"System Standby (Healthy)\";\n}\n\n// 5. Output Mapping\nconst gaugeMsgs = [\n    { payload: Number((prediction * 100).toFixed(1)), topic: \"Prediction\" },\n    { payload: Number(temp.toFixed(1)), topic: \"Temperature\" },\n    { payload: Number(sensors.Humidity ?? 0), topic: \"Humidity\" },\n    { payload: Number(moist.toFixed(1)), topic: \"Moisture\" }\n];\n\nconst controlMsg = { payload: sensorError ? \"ERROR\" : (ml_decision ? \"ON\" : \"OFF\") };\nconst alertMsg = { payload: statusMsg };\n\nreturn [gaugeMsgs, controlMsg, alertMsg];",
        "outputs": 3,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1010,
        "y": 380,
        "wires": [
