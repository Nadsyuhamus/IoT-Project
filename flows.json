    {
        "id": "e5e8134bdb5e0df5",
        "type": "function",
        "z": "538a03d09de52284",
        "name": "Preprocessing and Cleaning",
        "func": "if (msg.payload.Temperature_C && !isNaN(parseFloat(msg.payload.Temperature_C))) {\n    \n    if (msg.payload.Temperature_C > 60) msg.payload.Temperature_C = 60;\n    \n    msg.payload.Humidity = Math.min(Math.max(msg.payload.Humidity, 0), 100);\n    msg.payload.Soil_Moisture = Math.min(Math.max(msg.payload.Soil_Moisture, 0), 100);\n    msg.payload.Temperature = msg.payload.Temperature_C; // Standardize name for ML;\n\n    return msg; \n}\nreturn null; ",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
